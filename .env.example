# Copy to .env and fill in. .env is gitignored — secrets never leave this machine.

# SEC EDGAR requires a real identity with every request (no signup needed)
EDGAR_IDENTITY="Uday Kang uday.kang@martechs.io"

# Supabase project (Settings -> API)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Optional: direct Postgres connection string (Settings -> Database) so the
# pipeline can apply sql/schema.sql and future migrations itself.
SUPABASE_DB_URL=""

# Parallel.ai — optional if you authenticated via `parallel-cli login` (OAuth);
# the pipeline will try the CLI's stored credentials first, then this key.
PARALLEL_API_KEY=""

# v2 / production scoring via OpenRouter (unused in v1 — scoring runs through
# Claude Code Haiku subagents at no API cost)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-haiku-4.5"

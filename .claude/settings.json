{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv lock:*)",
      "Bash(uv pip:*)",
      "Bash(parallel-cli:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read(./**)",
      "Read(//Users/udaykang/AI_Public Traded/**)",
      "Bash(cat:*)",
      "Write(./data/scoring_results/**)",
      "Write(//Users/udaykang/AI_Public Traded/data/scoring_results/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Bash(cat .env:*)",
      "Bash(cat ./.env:*)",
      "Bash(cat \"/Users/udaykang/AI_Public Traded/.env\":*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session_status.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/run_tests.sh\""
          }
        ]
      }
    ]
  }
}
